---
import { hero } from "../lib/content";
import CopyButton from "./CopyButton.astro";
import HeroDiagram from "./HeroDiagram.astro";
---
<header class="mx-auto max-w-[var(--container-frame)] px-8 pt-[90px] pb-14">
  <p class="eyebrow mb-7">{hero.eyebrow}</p>
  <h1 class="font-sans font-medium text-[32px] md:text-[38px] leading-[1.15] tracking-[-0.02em] max-w-[18ch] mb-6">{hero.h1}</h1>
  <p class="prose-measure font-serif text-[20px] leading-[1.55] text-[var(--color-ink-muted)] mb-9">{hero.subhead}</p>
  <div class="flex items-center gap-5 flex-wrap">
    <div class="font-mono text-[14px] bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg px-4 py-3 flex items-start gap-3">
      <code class="whitespace-pre leading-[1.7]">{hero.install.map((c) => `$ ${c}`).join("\n")}</code>
      <CopyButton text={hero.install.join("\n")} />
    </div>
  </div>
  <HeroDiagram />
</header>
